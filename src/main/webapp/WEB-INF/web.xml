<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

  <display-name>SQL Trainer</display-name>

  <welcome-file-list>
    <welcome-file>pages/index.jsp</welcome-file>
  </welcome-file-list>

  <jsp-config>
    <jsp-property-group>
      <url-pattern>*.jsp</url-pattern>
      <page-encoding>UTF-8</page-encoding>
      <default-content-type>text/html;charset=UTF-8</default-content-type>
    </jsp-property-group>
  </jsp-config>

  <!-- ============================================ -->
  <!-- ФИЛЬТРЫ (порядок ВАЖЕН!)                    -->
  <!-- ============================================ -->

  <!-- 1. EncodingFilter - кодировка UTF-8 и CSP -->
  <filter>
    <filter-name>EncodingFilter</filter-name>
    <filter-class>com.sqltrainer.filter.EncodingFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>EncodingFilter</filter-name>
    <url-pattern>/*</url-pattern>
  </filter-mapping>

  <!-- 2. RateLimitFilter - ограничение частоты запросов -->
  <filter>
    <filter-name>RateLimitFilter</filter-name>
    <filter-class>com.sqltrainer.filter.RateLimitFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>RateLimitFilter</filter-name>
    <url-pattern>/*</url-pattern>
  </filter-mapping>

  <!-- 3. CsrfFilter - защита от CSRF -->
  <filter>
    <filter-name>CsrfFilter</filter-name>
    <filter-class>com.sqltrainer.filter.CsrfFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>CsrfFilter</filter-name>
    <url-pattern>/*</url-pattern>
  </filter-mapping>

  <!-- 4. TeacherFilter - проверка аутентификации -->
  <filter>
    <filter-name>TeacherFilter</filter-name>
    <filter-class>com.sqltrainer.filter.TeacherFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>TeacherFilter</filter-name>
    <url-pattern>/api/teacher</url-pattern>
    <url-pattern>/api/teacher/*</url-pattern>
  </filter-mapping>

</web-app>