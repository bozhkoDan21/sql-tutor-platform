# ============================================
# SQL Trainer - Environment Configuration
# ============================================
# Copy this file to .env and update with your values
# .env should NOT be committed to git!

# ============================================
# How to generate secure values:
#
# Generate JWT_SECRET (Linux/Mac/Git Bash):
#   openssl rand -base64 32
#
# Generate JWT_SECRET (PowerShell):
#   [Convert]::ToBase64String([System.Text.Encoding]::UTF8.GetBytes((New-Guid).Guid + (New-Guid).Guid))
#
# Generate database passwords:
#   openssl rand -base64 12
# ============================================

# ============================================
# Database configuration
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_ADMIN_USER=postgres
DB_ADMIN_PASSWORD=change_me
DB_TEACHER_USER=teacher_role
DB_TEACHER_PASSWORD=change_me
DB_STUDENT_USER=students
DB_STUDENT_PASSWORD=change_me

# ============================================
# Security (IMPORTANT!)
# ============================================
# Generate your own secret using one of the methods above
JWT_SECRET=change_me_generate_your_own_secret

# ============================================
# Query limits
# ============================================
QUERY_TIMEOUT_SEC=3
MAX_ROWS=1000
CONNECTION_TIMEOUT_MS=5000

# ============================================
# JWT Settings
# ============================================
JWT_ACCESS_TOKEN_EXPIRY_HOURS=1
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7
JWT_INACTIVE_TIMEOUT_HOURS=3

# ============================================
# Concurrency limits
# ============================================
MAX_CONCURRENT_QUERIES=10
SEMAPHORE_TIMEOUT_SEC=30

# ============================================
# Logging (DEBUG, INFO, WARN, ERROR)
# ============================================
LOG_LEVEL=INFO