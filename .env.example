# ============================================
# SQL Trainer - Environment Configuration
# ============================================
# Copy this file to .env and update with your values
# .env should NOT be committed to git!

# ============================================
# Database configuration
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_ADMIN_USER=postgres
DB_ADMIN_PASSWORD=change_me
DB_TEACHER_USER=teacher_role
DB_TEACHER_PASSWORD=change_me
DB_STUDENT_USER=students
DB_STUDENT_PASSWORD=change_me

# ============================================
# Teacher authentication (simple password)
# ============================================
TEACHER_PASSWORD=teacher123

# ============================================
# Query limits
# ============================================
QUERY_TIMEOUT_SEC=30
MAX_ROWS=1000
CONNECTION_TIMEOUT_MS=5000

# ============================================
# Concurrency limits
# ============================================
MAX_CONCURRENT_QUERIES=10
SEMAPHORE_TIMEOUT_SEC=30

# ============================================
# Logging (DEBUG, INFO, WARN, ERROR)
# ============================================
LOG_LEVEL=INFO